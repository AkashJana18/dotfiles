

# Config syntax crash course
# ==========================
# # The config file consists of simple key-value pairs,
# # separated by equals signs.
# font-family = Iosevka
# window-padding-x = 2
#
# # Spacing around the equals sign does not matter.
# # All of these are identical:
# key=value
# key= value
# key =value
# key = value
#
# # Any line beginning with a # is a comment. It's not possible to put
# # a comment after a config option, since it would be interpreted as a
# # part of the value. For example, this will have a value of "#123abc":
# background = #123abc
#
# # Empty values are used to reset config keys to default.
# key =
#
# # Some config options have unique syntaxes for their value,
# # which is explained in the docs for that config option.
# # Just for example:
# resize-overlay-duration = 4s 200ms

# --- Ghostty Configuration 1.2.3 ---

# Theme & Appearance
theme = niji
background-opacity = 0.6
background-blur-radius = 50
window-colorspace = display-p3
macos-titlebar-style = hidden
title = akaverselive

# Optional: makes the padding look uniform on all sides
window-padding-balance = true 
background-blur-radius = 20
macos-option-as-alt = true

# Window Geometry
window-width = 40
window-height = 20
window-padding-x = 10
window-padding-y = 10
resize-overlay = never
window-save-state = always

# Font
font-family = "MesloLGS NF"
font-size = 16

# Mouse & Interaction
mouse-hide-while-typing = true
mouse-scroll-multiplier = 2
confirm-close-surface = false

# Shell Integration
# Disables cursor/title control but keeps other features like prompt marking
shell-integration-features = no-cursor,sudo,no-title

# --- Keybindings ---
keybind = cmd+a=text:ggVG

# Custom Text Inputs
# Fixes potential newline issues in some shells
keybind = shift+enter=text:\n
